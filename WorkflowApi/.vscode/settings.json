{
  "json.schemas": [
    {
      "fileMatch": ["appsettings*.json"],
      "schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "properties": {
          "ConnectionStrings": {
            "type": "object",
            "properties": {
              "DefaultConnection": {
                "type": "string"
              }
            }
          },
          "Jwt": {
            "type": "object",
            "properties": {
              "Key": { "type": "string" },
              "Issuer": { "type": "string" },
              "Audience": { "type": "string" },
              "ExpiryMinutes": { "type": "string" }
            }
          },
          "Gcp": {
            "type": "object"
          },
          "Logging": {
            "type": "object"
          },
          "AllowedHosts": {
            "type": "string"
          }
        }
      }
    }
  ]
}
